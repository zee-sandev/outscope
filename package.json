{
  "name": "@outscope",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:packages": "pnpm --filter @outscope/nova build && pnpm --filter @outscope/nova-fn build && pnpm --filter @outscope/cli build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "pnpm --filter @outscope/nova test && pnpm --filter @outscope/nova-fn test && pnpm --filter @outscope/cli test",
    "audit:architecture": "depcruise --config .dependency-cruiser.cjs --exclude \"(^|/)(templates|generated|dist|node_modules)(/|$)\" \"packages/nova/src/**/*.ts\" \"packages/nova-fn/src/**/*.ts\" \"packages/cli/src/**/*.ts\" \"examples/*/src/**/*.ts\" && pnpm audit:agent-patterns",
    "audit:agent-patterns": "node scripts/audit-agent-patterns.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build:packages && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/node": "^24.10.1",
    "dependency-cruiser": "^17.3.1",
    "prettier": "^3.7.4",
    "turbo": "^2.7.4",
    "typescript": "5.9.2",
    "vitest": "^4.0.15"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "glob": "^11.0.0",
      "rimraf": "^6.0.0",
      "inflight": "npm:@pnpm/inflight@1.0.0"
    }
  }
}
